<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_act"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.yaqubabbasov.bobofood.ui.auth.login.Loginfragment"
        android:label="fragment_loginfragment"
        tools:layout="@layout/fragment_loginfragment" >
        <action
            android:id="@+id/loghomebridge"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/loginsignupbridge"
            app:destination="@id/signUpfragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:launchSingleTop="false"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.yaqubabbasov.bobofood.ui.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/homdetbridge"
            app:destination="@id/detailFragment" />
        <action
            android:id="@+id/homeprfbridge"
            app:destination="@id/profilFragment" />
    </fragment>
    <fragment
        android:id="@+id/detailFragment"
        android:name="com.yaqubabbasov.bobofood.ui.detail.DetailFragment"
        android:label="fragment_detail"
        tools:layout="@layout/fragment_detail" >
        <argument
            android:name="foodcl"
            app:argType="com.yaqubabbasov.bobofood.data.entity.Yemekler" />
        <action
            android:id="@+id/dtlcart"
            app:destination="@id/cartFragment" />
    </fragment>
    <fragment
        android:id="@+id/cartFragment"
        android:name="com.yaqubabbasov.bobofood.ui.cart.CartFragment"
        android:label="fragment_cart"
        tools:layout="@layout/fragment_cart" />
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.yaqubabbasov.bobofood.ui.splash.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash" >
        <action
            android:id="@+id/splash_viewpagerbridge"
            app:destination="@id/viewPagerFragment" />
        <action
            android:id="@+id/splashloginbridge"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/splash_home_bridge"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/splash_onboarding4_bridge"
            app:destination="@id/onBoarding4" />
    </fragment>
    <fragment
        android:id="@+id/viewPagerFragment"
        android:name="com.yaqubabbasov.bobofood.ui.viewpager.ViewPagerFragment"
        android:label="fragment_view_pager"
        tools:layout="@layout/fragment_view_pager" />
    <fragment
        android:id="@+id/signUpfragment"
        android:name="com.yaqubabbasov.bobofood.ui.auth.signup.SignUpfragment"
        android:label="SignUpfragment"
        tools:layout="@layout/fragment_sign_upfragment"
        >
        <action
            android:id="@+id/signloginbridge"
            app:destination="@id/loginFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
    </fragment>
    <fragment
        android:id="@+id/favouriteFragment"
        android:name="com.yaqubabbasov.bobofood.ui.favourite.FavouriteFragment"
        android:label="fragment_favourite"
        tools:layout="@layout/fragment_favourite" />
    <fragment
        android:id="@+id/onBoarding4"
        android:name="com.yaqubabbasov.bobofood.ui.onboarding.OnBoarding4"
        android:label="fragment_on_boarding4"
        tools:layout="@layout/fragment_on_boarding4" >
        <action
            android:id="@+id/onboard_homebridge"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/onborading4bridgelogin"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/profilFragment"
        android:name="com.yaqubabbasov.bobofood.ui.profil.ProfilFragment"
        android:label="fragment_profil"
        tools:layout="@layout/fragment_profil" />
</navigation>